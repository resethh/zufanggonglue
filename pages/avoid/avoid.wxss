.avoid-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-input {
  flex: 1;
  min-width: 0;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
}

.search-btn,
.reset-btn {
  flex: none;
  font-size: 26rpx;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
}

.search-btn {
  background: #2f6df6;
  color: #fff;
}

.reset-btn {
  color: #8a8a8a;
  background: #f0f1f5;
}

.list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.post-card:active {
  opacity: 0.7;
}

.post-head {
  margin-bottom: 12rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.post-content {
  font-size: 26rpx;
  color: #4a4a4a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-foot {
  margin-top: 14rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  background: #2f6df6;
  color: #fff;
  font-size: 28rpx;
  padding: 22rpx 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(47, 109, 246, 0.4);
}
